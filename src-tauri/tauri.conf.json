{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "hiyolabo-cockpit",
  "version": "0.1.0",
  "identifier": "com.hiyolabo.cockpit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "hiyolabo_main",
        "title": "Hiyolabo - Main",
        "width": 600,
        "height": 800,
        "x": 0,
        "y": 0,
        "url": "https://hiyolabo.site",
        "resizable": true,
        "decorations": true
      },
      {
        "label": "google_search",
        "title": "Google Search",
        "width": 600,
        "height": 800,
        "x": 600,
        "y": 0,
        "url": "https://www.google.com",
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
